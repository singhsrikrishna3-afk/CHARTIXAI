# S3 / MinIO (visual scan images)
S3_BUCKET=peestock-scans
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Data Feed
NSE_DATA_DIR=/app/data/nse
INTRADAY_TOP_N=400

# Razorpay
