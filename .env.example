# Database
DB_HOST=db
DB_PORT=5432
DB_USER=peestock
DB_PASSWORD=peestock_dev
DB_NAME=peestock
DATABASE_URL=postgresql+asyncpg://peestock:peestock_dev@db:5432/peestock

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=change-me-in-production
